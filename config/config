# hypr-wallpaper configuration
# All preferences live here. Topic rules are in rules.toml.
# NOTE: This file is sourced by bash — values with spaces must be quoted.

# ── Display ──
TRANSITION="--transition-type simple"
# For animated transitions, add params e.g.:
# TRANSITION="--transition-type grow --transition-duration 1.5 --transition-fps 60"
# Options: none|simple|fade|left|right|top|bottom|wipe|wave|grow|center|any|outer|random

# ── Quality gates ──
MIN_WIDTH="2560"             # Minimum image width in pixels
REDDIT_MIN_SCORE="500"       # Minimum Reddit post score
WALLHAVEN_MIN_FAVORITES="30" # Minimum Wallhaven favorites
WALLHAVEN_EXCLUDE_TAGS="women, anime"  # Comma-separated tags to exclude

# ── Behavior ──
LIKED_RESHOW_DAYS="14"       # Days before liked wallpaper can reshow
MAX_RETRIES="3"              # Fetch retry attempts
EXPLORE_HISTORY="3"          # Undo depth in explore mode (files kept on disk)
LIKED_HISTORY="50"           # Undo depth in liked mode
RULE_TIMEOUT="3"             # Seconds before a rule condition is killed
SOURCES="unsplash,reddit,wallhaven"  # Available sources
SOURCE_ORDER="ordered"               # "ordered" or "random"
LOG_MAX_LINES="500"                  # Keep last N log lines per run

# ── API keys ──
# Store in ~/.env (gitignored)
