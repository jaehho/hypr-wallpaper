#!/bin/bash
# hypr-wallpaper — SQLite-backed, quality-gated, time-aware wallpaper manager
# Usage:
#   hypr-wallpaper menu      # rofi GUI (mode-aware)
#   hypr-wallpaper next      # next wallpaper (mode-aware)
#   hypr-wallpaper prev      # previous wallpaper (undo)
#   hypr-wallpaper fetch     # fetch new from online
#   hypr-wallpaper like      # like current wallpaper
#   hypr-wallpaper dislike   # dislike current + show next
#   hypr-wallpaper source    # open source URL in browser
#   hypr-wallpaper mode      # toggle explore/liked mode
#   hypr-wallpaper restore   # restore last wallpaper (per-monitor aware)
#   hypr-wallpaper fill      # fill each monitor with a different liked wallpaper
#   hypr-wallpaper watch     # watch for new monitors and reapply

set -uo pipefail

# ── Paths ──
WALLDIR="$HOME/Pictures/wallpapers"
DATADIR="$HOME/.cache/wallpaper-data"
DBFILE="$DATADIR/wallpapers.db"
STATEFILE="$DATADIR/current"
MODEFILE="$DATADIR/mode"
HISTFILE_WP="$DATADIR/history"
CONFDIR="${XDG_CONFIG_HOME:-$HOME/.config}/hypr-wallpaper"
CONFFILE="$CONFDIR/config"
RULESFILE="$CONFDIR/rules.toml"
MONITOR_STATE_DIR="$DATADIR/monitors"

mkdir -p "$WALLDIR" "$DATADIR" "$MONITOR_STATE_DIR"

# ── Resolve active Hyprland instance ──
# HYPRLAND_INSTANCE_SIGNATURE can go stale after a session restart.
# Auto-detect the active instance by finding the directory with .socket.sock.
resolve_hyprland_instance() {
    if hyprctl monitors -j >/dev/null 2>&1; then
        return
    fi
    local hypr_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr"
    for dir in "$hypr_dir"/*/; do
        if [ -S "${dir}.socket.sock" ]; then
            export HYPRLAND_INSTANCE_SIGNATURE
            HYPRLAND_INSTANCE_SIGNATURE="$(basename "$dir")"
            return
        fi
    done
}
resolve_hyprland_instance

# ── Defaults ──
UA="hypr-wallpaper/1.0"

# ── Logging ──
LOGFILE="$DATADIR/hypr-wallpaper.log"
if [ -f "$LOGFILE" ]; then
    tail -n "${LOG_MAX_LINES:-500}" "$LOGFILE" > "$LOGFILE.tmp" && mv "$LOGFILE.tmp" "$LOGFILE"
fi
_c_reset='\033[0m'
_c_dim='\033[2m'
_c_bold='\033[1m'
_c_green='\033[32m'
_c_yellow='\033[33m'
_c_red='\033[31m'
_c_cyan='\033[36m'
_c_magenta='\033[35m'

_log_file() { printf "[%s] %s %s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$1" "$(echo -e "$2" | sed 's/\x1b\[[0-9;]*m//g')" >> "$LOGFILE"; }

log_step()  { printf "  ${_c_cyan}%s${_c_reset} %b\n" "$1" "$2"; _log_file "$1" "$2"; }
log_ok()    { printf "  ${_c_green}%s${_c_reset} %b\n" "$1" "$2"; _log_file "$1" "$2"; }
log_warn()  { printf "  ${_c_yellow}%s${_c_reset} %b\n" "$1" "$2"; _log_file "$1" "$2"; }
log_fail()  { printf "  ${_c_red}%s${_c_reset} %b\n" "$1" "$2"; _log_file "$1" "$2"; }
log_dim()   { printf "  ${_c_dim}%b${_c_reset}\n" "$1"; _log_file "-" "$1"; }

# Notification that replaces itself (mako tag)
notify_progress() {
    notify-send -u low -h "string:x-canonical-private-synchronous:hypr-wallpaper" "Wallpaper" "$1"
}

# ── Load user config ──
# shellcheck disable=SC1090
[ -f "$CONFFILE" ] && source "$CONFFILE"
[ -f "$HOME/.env" ] && source "$HOME/.env"

# ── Initialize SQLite database ──
init_db() {
    sqlite3 "$DBFILE" "
    CREATE TABLE IF NOT EXISTS wallpapers (
        filename     TEXT PRIMARY KEY,
        image_url    TEXT,
        source_url   TEXT,
        source       TEXT,
        topic        TEXT,
        status       TEXT DEFAULT 'unrated',
        fetch_date   TEXT,
        last_shown   TEXT,
        width        INTEGER,
        height       INTEGER
    );
    CREATE INDEX IF NOT EXISTS idx_status ON wallpapers(status);
    "
}
init_db
db_exec "UPDATE wallpapers SET status = 'unrated' WHERE status = 'unseen';" 2>/dev/null

# ── DB helpers ──
db_query() { sqlite3 -separator $'\t' "$DBFILE" "$1"; }
db_exec()  { sqlite3 "$DBFILE" "$1"; }

db_get_field() {
    db_query "SELECT $2 FROM wallpapers WHERE filename = '$(sql_escape "$1")' LIMIT 1;"
}

sql_escape() { echo "${1//\'/\'\'}"; }

db_add() {
    db_exec "INSERT OR IGNORE INTO wallpapers (filename, image_url, source_url, source, topic, status, fetch_date)
             VALUES ('$(sql_escape "$1")', '$(sql_escape "$2")', '$(sql_escape "$3")', '$(sql_escape "$4")', '$(sql_escape "$5")', 'unrated', '$(date +%Y-%m-%d)');"
}

db_set_status() {
    db_exec "UPDATE wallpapers SET status = '$(sql_escape "$2")' WHERE filename = '$(sql_escape "$1")';"
}

db_set_last_shown() {
    db_exec "UPDATE wallpapers SET last_shown = '$(date +%Y-%m-%d)' WHERE filename = '$(sql_escape "$1")';"
}

db_url_exists() {
    local count
    count=$(db_query "SELECT COUNT(*) FROM wallpapers WHERE image_url = '$(sql_escape "$1")';")
    [ "$count" -gt 0 ]
}

# ── State helpers ──
current_file()     { cat "$STATEFILE" 2>/dev/null; }
current_basename() { local c; c=$(current_file); [ -n "$c" ] && basename "$c"; }
current_mode()     { cat "$MODEFILE" 2>/dev/null || echo "explore"; }

# ── Per-monitor helpers ──
get_outputs() { hyprctl monitors -j 2>/dev/null | jq -r '.[].name'; }
get_focused_output() { hyprctl monitors -j 2>/dev/null | jq -r '.[] | select(.focused) | .name'; }
save_monitor_state() { echo "$2" > "$MONITOR_STATE_DIR/$1"; }

pick_random_liked_excluding() {
    local exclude_clause=""
    for name in "$@"; do
        [ -z "$name" ] && continue
        exclude_clause+=" AND filename != '$(sql_escape "$name")'"
    done
    db_query "SELECT filename FROM wallpapers WHERE status = 'liked' $exclude_clause ORDER BY RANDOM() LIMIT 1;"
}

fill_other_monitors() {
    local primary_path="$1"
    local outputs
    mapfile -t outputs < <(get_outputs)
    [ ${#outputs[@]} -le 1 ] && return

    local focused
    focused=$(get_focused_output)
    local used=("$(basename "$primary_path")")

    for output in "${outputs[@]}"; do
        [ "$output" = "$focused" ] && continue
        local pick
        pick=$(pick_random_liked_excluding "${used[@]}")
        if [ -n "$pick" ] && [ -f "$WALLDIR/$pick" ]; then
            awww img "$WALLDIR/$pick" -o "$output" --transition-type none
            save_monitor_state "$output" "$WALLDIR/$pick"
            used+=("$pick")
        else
            awww img "$primary_path" -o "$output" --transition-type none
            save_monitor_state "$output" "$primary_path"
        fi
    done
}

# ── History ──
history_push() {
    local filepath="$1"
    [ -z "$filepath" ] || [ ! -f "$filepath" ] && return
    echo "$filepath" >> "$HISTFILE_WP"

    local mode
    mode=$(current_mode)
    local max_hist
    if [ "$mode" = "liked" ]; then
        max_hist=$LIKED_HISTORY
    else
        max_hist=$EXPLORE_HISTORY
    fi

    local count
    count=$(wc -l < "$HISTFILE_WP" 2>/dev/null || echo 0)
    if [ "$count" -gt "$max_hist" ]; then
        local trim_count=$((count - max_hist))
        head -n "$trim_count" "$HISTFILE_WP" | while IFS= read -r old; do
            [ -z "$old" ] && continue
            local old_name
            old_name=$(basename "$old")
            local status
            status=$(db_get_field "$old_name" "status")
            if [ "$status" != "liked" ] && [ -f "$old" ]; then
                rm -f "$old"
            fi
        done
        tail -n "$max_hist" "$HISTFILE_WP" > "$HISTFILE_WP.tmp"
        mv "$HISTFILE_WP.tmp" "$HISTFILE_WP"
    fi
}

do_prev() {
    [ ! -f "$HISTFILE_WP" ] && { notify-send -u low "Wallpaper" "No history"; return; }

    while true; do
        local prev
        prev=$(tail -1 "$HISTFILE_WP" 2>/dev/null)
        [ -z "$prev" ] && { notify-send -u low "Wallpaper" "No more history"; return; }

        # Pop last entry
        head -n -1 "$HISTFILE_WP" > "$HISTFILE_WP.tmp" && mv "$HISTFILE_WP.tmp" "$HISTFILE_WP"

        if [ -f "$prev" ]; then
            set_wallpaper "$prev"
            notify-send -u low "Wallpaper" "$(basename "$prev")"
            return
        fi
    done
}

# ── Rule-based topic selection ──
# Reads rules.toml — each section has an optional condition (shell command)
# and a topics list. All matching rules' topics are pooled together.
# Sections with no condition always match (defaults/fallbacks).
pick_topic() {
    if [ ! -f "$RULESFILE" ]; then
        log_warn "!" "No rules file, using fallback"
        echo "landscape"
        return
    fi

    local rules rule_names
    rule_names=$(tomlq -r 'keys[]' "$RULESFILE" 2>/dev/null)
    [ -z "$rule_names" ] && { log_warn "!" "Empty rules file"; echo "landscape"; return; }

    log_step "~" "Evaluating rules..." >&2

    local pool=() matched_names=()
    while IFS= read -r name; do
        [ -z "$name" ] && continue
        local condition topics_json
        condition=$(tomlq -r ".\"$name\".condition // \"\"" "$RULESFILE")
        topics_json=$(tomlq -r ".\"$name\".topics // [] | .[]" "$RULESFILE")

        [ -z "$topics_json" ] && continue

        local match=false
        if [ -z "$condition" ]; then
            match=true
        elif timeout "$RULE_TIMEOUT" bash -c "$condition" >/dev/null 2>&1; then
            match=true
        fi

        if [ "$match" = true ]; then
            matched_names+=("$name")
            local rule_topics=()
            while IFS= read -r t; do
                [ -n "$t" ] && { pool+=("$t"); rule_topics+=("$t"); }
            done <<< "$topics_json"
            log_ok "+" "$name" >&2
            log_dim "      $(printf '%s, ' "${rule_topics[@]}" | sed 's/, $//')" >&2
        else
            log_dim "- $name" >&2
        fi
    done <<< "$rule_names"

    if [ ${#pool[@]} -eq 0 ]; then
        log_warn "!" "No rules matched, using fallback" >&2
        echo "landscape"
        return
    fi

    if [ ${#matched_names[@]} -gt 1 ]; then
        echo "" >&2
        log_step "=" "${#pool[@]} topics combined from: ${_c_bold}${matched_names[*]}${_c_reset}" >&2
    fi

    local pick="${pool[$((RANDOM % ${#pool[@]}))]}"
    echo "" >&2
    log_step "*" "Selected: ${_c_bold}$pick${_c_reset}" >&2
    echo "$pick"
}

# ── Fetch: Reddit ──
# Exit codes: 1 = API/network error, 2 = no quality matches, 3 = all already seen
fetch_reddit() {
    local topic="$1"
    local sub
    case "$topic" in
        *architecture*|*city*|*bridge*|*harbor*|*neon*|*skyline*) sub="ArchitecturePorn" ;;
        *stars*|*aurora*|*milky*|*northern*|*moon*|*observatory*) sub="SkyPorn" ;;
        *sunset*|*golden*|*twilight*) sub="EarthPorn" ;;
        *night*) sub="CityPorn" ;;
        *) sub="EarthPorn" ;;
    esac

    local json
    json=$(curl -sf --max-time 15 \
        "https://www.reddit.com/r/$sub/top.json?t=all&limit=50" \
        -H "User-Agent: $UA") || return 1

    local posts
    posts=$(echo "$json" | jq -c --argjson min_score "$REDDIT_MIN_SCORE" --argjson min_w "$MIN_WIDTH" '
        [.data.children[].data
         | select(.over_18 != true)
         | select(.score >= $min_score)
         | select(.url | test("\\.(jpg|jpeg|png|webp|gif)$"; "i"))
         | select((.preview.images[0].source.width // 0) >= $min_w)
         | select((.preview.images[0].source.width // 0) > (.preview.images[0].source.height // 0))
         | { url: .url, source: ("https://reddit.com" + .permalink),
             w: .preview.images[0].source.width, h: .preview.images[0].source.height }
        ] | .[]') || return 2

    [ -z "$posts" ] && return 2

    while IFS= read -r post; do
        [ -z "$post" ] && continue
        local url
        url=$(echo "$post" | jq -r '.url')
        if ! db_url_exists "$url"; then
            echo "$post" | jq -r '[.url, .source, .w, .h] | @tsv'
            return 0
        fi
    done <<< "$posts"

    return 3
}

# ── Fetch: Wallhaven ──
fetch_wallhaven() {
    local topic="$1"
    local query="${topic// /+}"
    local exclude=""
    if [ -n "$WALLHAVEN_EXCLUDE_TAGS" ]; then
        local tags="${WALLHAVEN_EXCLUDE_TAGS// /}"
        exclude="+-${tags//,/+-}"
    fi

    local json
    json=$(curl -sf --max-time 15 \
        "https://wallhaven.cc/api/v1/search?q=${query}${exclude}&sorting=favorites&atleast=${MIN_WIDTH}x$((MIN_WIDTH * 9 / 16))&purity=100&page=1") || return 1

    local posts
    posts=$(echo "$json" | jq -c --argjson min_fav "$WALLHAVEN_MIN_FAVORITES" '
        [.data[]
         | select(.favorites >= $min_fav)
         | { url: .path, source: .url,
             w: .dimension_x, h: .dimension_y }
        ] | .[]') || return 2

    [ -z "$posts" ] && return 2

    while IFS= read -r post; do
        [ -z "$post" ] && continue
        local url
        url=$(echo "$post" | jq -r '.url')
        if ! db_url_exists "$url"; then
            echo "$post" | jq -r '[.url, .source, .w, .h] | @tsv'
            return 0
        fi
    done <<< "$posts"

    return 3
}

# ── Fetch: Unsplash ──
fetch_unsplash() {
    local topic="$1"
    local key="${UNSPLASH_ACCESS_KEY:-}"
    [ -z "$key" ] && return 1

    local query="${topic// /+}"
    local json
    json=$(curl -sf --max-time 15 \
        "https://api.unsplash.com/photos/random?query=$query&orientation=landscape&client_id=$key") || return 1

    local url source_url w h
    url=$(echo "$json" | jq -r '.urls.full // empty')
    source_url=$(echo "$json" | jq -r '.links.html // empty')
    w=$(echo "$json" | jq -r '.width // 0')
    h=$(echo "$json" | jq -r '.height // 0')
    [ -z "$url" ] && return 2

    if ! db_url_exists "$url"; then
        printf '%s\t%s\t%s\t%s\n' "$url" "$source_url" "$w" "$h"
        return 0
    fi
    return 3
}

# ── Download and register ──
do_fetch() {
    printf "\n  ${_c_bold}Wallpaper Fetch${_c_reset}\n\n"

    local attempt=0
    while [ "$attempt" -lt "$MAX_RETRIES" ]; do
        ((attempt++))
        [ "$attempt" -gt 1 ] && echo "" && log_warn "~" "Retry $attempt/$MAX_RETRIES..."

        local topic result="" source_name=""
        topic=$(pick_topic)
        notify_progress "Searching for \"$topic\"..."

        IFS=',' read -ra sources <<< "${SOURCES:-reddit,wallhaven,unsplash}"
        # Filter out unsplash if no API key
        local filtered=()
        for s in "${sources[@]}"; do
            s="${s// /}"
            [ "$s" = "unsplash" ] && [ -z "${UNSPLASH_ACCESS_KEY:-}" ] && continue
            filtered+=("$s")
        done
        sources=("${filtered[@]}")
        # Shuffle if configured
        if [ "${SOURCE_ORDER:-ordered}" = "random" ]; then
            local i j tmp
            for ((i=${#sources[@]}-1; i>0; i--)); do
                j=$((RANDOM % (i+1)))
                tmp="${sources[$i]}"
                sources[$i]="${sources[$j]}"
                sources[$j]="$tmp"
            done
        fi

        echo ""
        for src in "${sources[@]}"; do
            log_step ">" "Trying $src..."
            notify_progress "Trying $src for \"$topic\"..."
            local rc=0
            case $src in
                reddit)    result=$(fetch_reddit "$topic" 2>/dev/null) || rc=$? ;;
                wallhaven) result=$(fetch_wallhaven "$topic" 2>/dev/null) || rc=$? ;;
                unsplash)  result=$(fetch_unsplash "$topic" 2>/dev/null) || rc=$? ;;
            esac
            if [ -n "$result" ]; then
                source_name=$src
                log_ok "+" "Found on $src"
                break
            else
                case $rc in
                    1) log_fail "x" "$src: API request failed (network/timeout)" ;;
                    2) log_warn "-" "$src: no results for \"$topic\" (quality gate)" ;;
                    3) log_warn "-" "$src: all results already seen" ;;
                    *) log_dim "  - $src: no match" ;;
                esac
            fi
        done

        [ -z "$result" ] && continue

        # ── Download ──
        local img_url source_url w h
        IFS=$'\t' read -r img_url source_url w h <<< "$result"

        local ext="${img_url##*.}"
        ext="${ext%%\?*}"
        [[ "$ext" =~ ^(jpg|jpeg|png|webp)$ ]] || ext="jpg"
        local filename="$(date +%Y%m%d-%H%M%S)-${source_name}.${ext}"
        local filepath="$WALLDIR/$filename"

        echo ""
        log_step ">" "Downloading ${w}x${h} from $source_name..."
        notify_progress "Downloading ${w}x${h} from $source_name..."
        local curl_out
        if ! curl_out=$(curl -sf --max-time 30 -w "%{http_code}" -o "$filepath" "$img_url" 2>&1); then
            local http_code="${curl_out: -3}"
            rm -f "$filepath"
            local dl_err=""
            case "$http_code" in
                000) dl_err="connection timeout" ;;
                403) dl_err="access denied (403)" ;;
                404) dl_err="image not found (404)" ;;
                429) dl_err="rate limited (429)" ;;
                *)   dl_err="HTTP $http_code" ;;
            esac
            log_fail "x" "Download failed: $dl_err"
            notify_progress "Download failed: $dl_err, retrying..."
            continue
        fi

        # ── Success ──
        db_add "$filename" "$img_url" "$source_url" "$source_name" "$topic"
        db_exec "UPDATE wallpapers SET width=${w:-0}, height=${h:-0} WHERE filename='$(sql_escape "$filename")';"

        local cur; cur=$(current_file)
        [ -n "$cur" ] && [ -f "$cur" ] && history_push "$cur"

        log_step ">" "Applying..."
        set_wallpaper "$filepath"

        echo ""
        log_ok "#" "${_c_bold}$topic${_c_reset}  ${_c_dim}($source_name, ${w}x${h})${_c_reset}"
        echo ""
        notify_progress "$topic ($source_name, ${w}x${h})"
        return 0
    done

    # ── All retries exhausted — offline fallback ──
    local fallback
    fallback=$(db_query "SELECT filename FROM wallpapers WHERE status = 'liked' ORDER BY RANDOM() LIMIT 1;")
    if [ -n "$fallback" ] && [ -f "$WALLDIR/$fallback" ]; then
        local cur; cur=$(current_file)
        [ -n "$cur" ] && [ -f "$cur" ] && history_push "$cur"
        set_wallpaper "$WALLDIR/$fallback"
        echo ""
        log_warn "#" "Using liked wallpaper: $fallback"
        notify_progress "Offline — $fallback"
        return 0
    fi
    echo ""
    log_fail "x" "All $MAX_RETRIES attempts failed and no liked wallpapers available"
    notify-send -u normal "Wallpaper" "Failed to fetch wallpaper"
    return 1
}

# ── Cleanup outgoing wallpaper if not liked or in history ──
cleanup_current() {
    local name
    name=$(current_basename)
    [ -z "$name" ] && return
    local status
    status=$(db_get_field "$name" "status")
    [ "$status" = "liked" ] && return
    local cur
    cur=$(current_file)
    if [ -f "$HISTFILE_WP" ] && grep -qF "$cur" "$HISTFILE_WP"; then
        return
    fi
    rm -f "$WALLDIR/$name"
}

# ── Set wallpaper via awww ──
set_wallpaper() {
    local filepath="$1"
    cleanup_current
    pgrep -x awww-daemon >/dev/null || { awww-daemon 2>/dev/null & sleep 0.5; }

    local outputs
    mapfile -t outputs < <(get_outputs)

    if [ ${#outputs[@]} -le 1 ]; then
        eval awww img "\"$filepath\"" $TRANSITION
    else
        local focused
        focused=$(get_focused_output)
        eval awww img "\"$filepath\"" -o "\"$focused\"" $TRANSITION
        save_monitor_state "$focused" "$filepath"
        fill_other_monitors "$filepath"
    fi

    echo "$filepath" > "$STATEFILE"
    db_set_last_shown "$(basename "$filepath")"
}

# ── Next wallpaper (mode-aware) ──
do_next() {
    local mode
    mode=$(current_mode)
    if [ "$mode" = "liked" ]; then
        do_next_liked
    else
        do_fetch
    fi
}

do_next_liked() {
    local current_name
    current_name=$(current_basename)
    local esc_current
    esc_current=$(sql_escape "$current_name")

    local pick
    pick=$(db_query "SELECT filename FROM wallpapers
                     WHERE status = 'liked' AND filename != '$esc_current'
                     ORDER BY RANDOM() LIMIT 1;")

    if [ -z "$pick" ] || [ ! -f "$WALLDIR/$pick" ]; then
        notify-send -u low "Wallpaper" "No liked wallpapers available"
        return
    fi

    local cur; cur=$(current_file)
    [ -n "$cur" ] && [ -f "$cur" ] && history_push "$cur"
    set_wallpaper "$WALLDIR/$pick"
    notify-send -u low "Wallpaper" "$pick"
}

# ── Mode toggle ──
do_toggle_mode() {
    local mode
    mode=$(current_mode)
    if [ "$mode" = "explore" ]; then
        echo "liked" > "$MODEFILE"
        notify-send -u low "Wallpaper" "Switched to liked mode"
        do_next_liked
    else
        echo "explore" > "$MODEFILE"
        notify-send -u low "Wallpaper" "Switched to explore mode"
        do_fetch
    fi
}

# ── Status icon for wallpaper state ──
status_icon() {
    case "$1" in
        liked)    echo "♥" ;;
        disliked) echo "✗" ;;
        *)        echo "○" ;;
    esac
}

# ── Menu status info ──
menu_status() {
    local name topic source status liked_count icon
    name=$(current_basename)

    if [ -n "$name" ]; then
        topic=$(db_get_field "$name" "topic")
        source=$(db_get_field "$name" "source")
        status=$(db_get_field "$name" "status")
        icon=$(status_icon "$status")
    fi

    # Active rules
    local active_rules=()
    if [ -f "$RULESFILE" ]; then
        local rule_names
        rule_names=$(tomlq -r 'keys[]' "$RULESFILE" 2>/dev/null)
        while IFS= read -r rname; do
            [ -z "$rname" ] && continue
            local condition
            condition=$(tomlq -r ".\"$rname\".condition // \"\"" "$RULESFILE")
            if [ -z "$condition" ] || timeout "$RULE_TIMEOUT" bash -c "$condition" >/dev/null 2>&1; then
                active_rules+=("$rname")
            fi
        done <<< "$rule_names"
    fi

    local lines=()
    [ -n "$topic" ] && lines+=("$icon $topic ($source)")
    [ ${#active_rules[@]} -gt 0 ] && lines+=("Active: ${active_rules[*]}")
    printf '%s\n' "${lines[@]}"
}

# ── More menu ──
do_more() {
    local items=(
        "  Edit rules"
        "  Edit settings"
        "  View log"
    )

    local choice
    choice=$(printf '%s\n' "${items[@]}" \
        | rofi -dmenu -i -p "More" \
            -theme-str "listview { lines: ${#items[@]}; } window { width: 400px; }")

    case "$choice" in
        *"rules"*)    kitty --title "Wallpaper Rules" -- "${EDITOR:-nvim}" "$RULESFILE" &disown ;;
        *"settings"*) kitty --title "Wallpaper Settings" -- "${EDITOR:-nvim}" "$CONFFILE" &disown ;;
        *"log"*)      kitty --title "Wallpaper Log" -- "${EDITOR:-nvim}" -R "+$" "$LOGFILE" &disown ;;
    esac
}

# ── Rofi menu ──
do_menu() {
    local mode
    mode=$(current_mode)

    local status_lines
    status_lines=$(menu_status)
    local mesg_flag=()
    [ -n "$status_lines" ] && mesg_flag=(-mesg "$status_lines")

    local items=()
    if [ "$mode" = "explore" ]; then
        items+=(
            "  Next"
            "  Prev"
            "  Like"
            "  Dislike"
            "  Switch to liked mode"
            "  Open source"
            "  More"
        )
    else
        items+=(
            "  Next"
            "  Prev"
            "  Browse"
            "  Dislike"
            "  Switch to explore mode"
            "  Open source"
            "  More"
        )
    fi

    local choice
    choice=$(printf '%s\n' "${items[@]}" \
        | rofi -dmenu -i -p "Wallpaper ($mode)" \
            "${mesg_flag[@]}" \
            -theme-str "listview { lines: ${#items[@]}; } window { width: 400px; }")

    case "$choice" in
        *"Next"*)       do_next ;;
        *"Prev"*)       do_prev ;;
        *"Like"*)       do_like ;;
        *"Dislike"*)    do_dislike ;;
        *"Browse"*)     do_browse_liked ;;
        *"Switch"*)     do_toggle_mode ;;
        *"source"*)     do_source ;;
        *"More"*)       do_more ;;
    esac
}

# ── Browse liked with rofi preview ──
do_browse_liked() {
    local liked_files
    liked_files=$(db_query "SELECT filename FROM wallpapers WHERE status = 'liked' ORDER BY fetch_date DESC;")
    [ -z "$liked_files" ] && { notify-send -u low "Wallpaper" "No liked wallpapers"; return; }

    local pick
    pick=$(while IFS= read -r fname; do
        [ -z "$fname" ] && continue
        [ ! -f "$WALLDIR/$fname" ] && continue
        local topic
        topic=$(db_get_field "$fname" "topic")
        printf '%s — %s\0icon\x1f%s\n' "$fname" "$topic" "$WALLDIR/$fname"
    done <<< "$liked_files" \
        | rofi -dmenu -i -p "Liked" -show-icons \
            -theme-str 'listview { lines: 8; } window { width: 600px; } element-icon { size: 80px; }')

    [ -z "$pick" ] && return
    local filename="${pick%% — *}"

    if [ -f "$WALLDIR/$filename" ]; then
        local cur; cur=$(current_file)
        [ -n "$cur" ] && [ -f "$cur" ] && history_push "$cur"
        set_wallpaper "$WALLDIR/$filename"
    fi
}

do_like() {
    local name
    name=$(current_basename)
    [ -z "$name" ] && return
    db_set_status "$name" "liked"
    notify-send -u low "Wallpaper" "Liked"
}

do_dislike() {
    local name
    name=$(current_basename)
    [ -z "$name" ] && return
    db_set_status "$name" "disliked"
    notify-send -u low "Wallpaper" "Disliked"
    do_next
}

do_source() {
    local name
    name=$(current_basename)
    [ -z "$name" ] && return
    local url
    url=$(db_get_field "$name" "source_url")
    if [ -n "$url" ]; then
        xdg-open "$url" &disown
    else
        notify-send -u low "Wallpaper" "No source URL available"
    fi
}

do_restore() {
    pgrep -x awww-daemon >/dev/null || { awww-daemon 2>/dev/null & sleep 0.5; }

    local outputs
    mapfile -t outputs < <(get_outputs)
    local restored=false

    if [ ${#outputs[@]} -gt 1 ] && [ -d "$MONITOR_STATE_DIR" ]; then
        for output in "${outputs[@]}"; do
            local state_file="$MONITOR_STATE_DIR/$output"
            if [ -f "$state_file" ]; then
                local wp
                wp=$(cat "$state_file")
                if [ -n "$wp" ] && [ -f "$wp" ]; then
                    awww img "$wp" -o "$output" --transition-type none
                    restored=true
                fi
            fi
        done
    fi

    if [ "$restored" = false ]; then
        local last
        last=$(current_file)
        if [ -n "$last" ] && [ -f "$last" ]; then
            awww img "$last" --transition-type none
        fi
    fi
}

# ── Watch for new monitors ──
do_watch() {
    socat -U - "UNIX-CONNECT:${XDG_RUNTIME_DIR}/hypr/${HYPRLAND_INSTANCE_SIGNATURE}/.socket2.sock" | while read -r event; do
        case "$event" in
            monitoradded*)
                sleep 1
                local new_output="${event#monitoradded>>}"
                pgrep -x awww-daemon >/dev/null || { awww-daemon 2>/dev/null & sleep 0.5; }
                # Check for saved state first
                if [ -f "$MONITOR_STATE_DIR/$new_output" ]; then
                    local saved_wp
                    saved_wp=$(cat "$MONITOR_STATE_DIR/$new_output")
                    if [ -n "$saved_wp" ] && [ -f "$saved_wp" ]; then
                        awww img "$saved_wp" -o "$new_output" --transition-type none
                        continue
                    fi
                fi
                # No saved state — pick a random liked wallpaper
                local pick
                pick=$(db_query "SELECT filename FROM wallpapers WHERE status = 'liked' ORDER BY RANDOM() LIMIT 1;")
                if [ -n "$pick" ] && [ -f "$WALLDIR/$pick" ]; then
                    awww img "$WALLDIR/$pick" -o "$new_output" --transition-type none
                    save_monitor_state "$new_output" "$WALLDIR/$pick"
                else
                    do_restore
                fi
                ;;
        esac
    done
}

# ── Fill all monitors with different liked wallpapers ──
do_fill_monitors() {
    pgrep -x awww-daemon >/dev/null || { awww-daemon 2>/dev/null & sleep 0.5; }
    local outputs
    mapfile -t outputs < <(get_outputs)
    if [ ${#outputs[@]} -le 1 ]; then
        notify-send -u low "Wallpaper" "Only one monitor — nothing to fill"
        return
    fi

    local used=()
    for output in "${outputs[@]}"; do
        local pick
        pick=$(pick_random_liked_excluding "${used[@]}")
        if [ -n "$pick" ] && [ -f "$WALLDIR/$pick" ]; then
            awww img "$WALLDIR/$pick" -o "$output" --transition-type none
            save_monitor_state "$output" "$WALLDIR/$pick"
            used+=("$pick")
        fi
    done
    notify-send -u low "Wallpaper" "Filled ${#outputs[@]} monitors"
}

# ── Migrate from old TSV if it exists ──
migrate_tsv() {
    local old="$DATADIR/db.tsv"
    [ -f "$old" ] || return
    while IFS=$'\t' read -r fname source_url status topic fetch_date last_shown; do
        [ -z "$fname" ] && continue
        db_exec "INSERT OR IGNORE INTO wallpapers (filename, source_url, status, topic, fetch_date, last_shown, source)
                 VALUES ('$(sql_escape "$fname")', '$(sql_escape "$source_url")', '$(sql_escape "$status")', '$(sql_escape "$topic")', '$(sql_escape "$fetch_date")', '$(sql_escape "$last_shown")', '');"
    done < "$old"
    mv "$old" "$old.migrated"
}
migrate_tsv 2>/dev/null

# ── Main ──
case "${1:-menu}" in
    menu)    do_menu ;;
    next)    do_next ;;
    prev)    do_prev ;;
    fetch)   do_fetch ;;
    like)    do_like ;;
    dislike) do_dislike ;;
    source)  do_source ;;
    mode)    do_toggle_mode ;;
    restore) do_restore ;;
    fill)    do_fill_monitors ;;
    set)     [ -f "$2" ] && { local c; c=$(current_file); [ -n "$c" ] && [ -f "$c" ] && history_push "$c"; set_wallpaper "$2"; } ;;
    watch)   do_watch ;;
    *)       echo "Usage: hypr-wallpaper {menu|next|prev|fetch|like|dislike|source|mode|set|restore|fill|watch}" ;;
esac
