#!/usr/bin/env python3
"""TUI wallpaper manager for Hyprland — launched via kitty popup."""

import curses
import json
import os
import re
import sqlite3
import subprocess
import sys

# Resolve hypr_tui: installed lib or dev submodule
_here = os.path.dirname(os.path.realpath(__file__))
for _p in [os.path.join(_here, "..", "lib", "hypr-wallpaper"),
           os.path.join(_here, "..", "hypr-tui")]:
    if os.path.isdir(os.path.join(_p, "hypr_tui")):
        sys.path.insert(0, _p)
        break

from hypr_tui import (
    C_ACCENT, C_BRIGHT, C_DIM, C_HEADER, C_KEY, C_NORMAL, C_SELECTED,
    draw_box, draw_hints, draw_line, draw_sep, init_colors, show_help,
)

WALLDIR = os.path.expanduser("~/Pictures/wallpapers")
DATADIR = os.path.expanduser("~/.cache/wallpaper-data")
DBFILE = f"{DATADIR}/wallpapers.db"
STATEFILE = f"{DATADIR}/current"
MODEFILE = f"{DATADIR}/mode"
WP_CMD = "hypr-wallpaper"
CONFDIR = os.path.expanduser(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config"))
    + "/hypr-wallpaper"
)
CONFFILE = f"{CONFDIR}/config"
RULESFILE = f"{CONFDIR}/rules.toml"
LOGFILE = f"{DATADIR}/hypr-wallpaper.log"

# ── data helpers ─────────────────────────────────────────────────────


def wp_cmd(*args):
    """Run command and wait (for instant ops like like/dislike)."""
    subprocess.run([WP_CMD] + list(args), capture_output=True, text=True)


def wp_cmd_bg(*args):
    """Run command in background (for slow ops like next/fetch)."""
    subprocess.Popen([WP_CMD] + list(args),
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def db_query(sql):
    try:
        conn = sqlite3.connect(DBFILE)
        rows = conn.execute(sql).fetchall()
        conn.close()
        return rows
    except Exception:
        return []


def get_state():
    current = ""
    try:
        with open(STATEFILE) as f:
            current = f.read().strip()
    except FileNotFoundError:
        pass
    mode = "explore"
    try:
        with open(MODEFILE) as f:
            mode = f.read().strip() or "explore"
    except FileNotFoundError:
        pass
    basename = os.path.basename(current) if current else ""
    topic = source = status = ""
    if basename:
        rows = db_query(
            f"SELECT topic, source, status FROM wallpapers "
            f"WHERE filename = '{basename.replace(chr(39), chr(39)*2)}' LIMIT 1"
        )
        if rows:
            topic, source, status = rows[0]
    liked = db_query("SELECT COUNT(*) FROM wallpapers WHERE status = 'liked'")
    unrated = db_query("SELECT COUNT(*) FROM wallpapers WHERE status = 'unrated'")
    return {
        "file": basename, "mode": mode, "topic": topic or "\u2014",
        "source": source or "\u2014", "status": status or "\u2014",
        "liked": liked[0][0] if liked else 0,
        "unrated": unrated[0][0] if unrated else 0,
    }


def get_liked_wallpapers():
    rows = db_query(
        "SELECT filename, topic FROM wallpapers "
        "WHERE status = 'liked' ORDER BY fetch_date DESC"
    )
    return [{"file": r[0], "topic": r[1] or "\u2014"} for r in rows]


STATUS_ICONS = {"liked": "\uf004", "disliked": "\uf00d", "unrated": "\uf128"}


# ── drawing primitives ───────────────────────────────────────────────


def text_input(stdscr, y, x, w, prompt, initial=""):
    """Multi-line wrapping text input. Renders from y upward as needed."""
    text = initial
    cur = len(text)  # cursor position in text
    curses.curs_set(1)
    while True:
        # Build wrapped display: prompt + text, wrapped to width w
        full = prompt + text
        lines = _wrap(full, w) or [""]
        nlines = len(lines)
        # Draw from y upward (so the bottom line is always at y)
        start_y = y - nlines + 1
        for i, line in enumerate(lines):
            row = start_y + i
            try:
                stdscr.addstr(row, x, " " * w, curses.color_pair(C_NORMAL))
                if i == 0:
                    # First line has the prompt highlighted
                    stdscr.addstr(row, x, prompt,
                                  curses.color_pair(C_KEY) | curses.A_BOLD)
                    stdscr.addstr(line[len(prompt):],
                                  curses.color_pair(C_NORMAL))
                else:
                    stdscr.addstr(row, x, line,
                                  curses.color_pair(C_NORMAL))
            except curses.error:
                pass
        # Place cursor: find which line/col the cursor is at
        cursor_pos = len(prompt) + cur
        cy, cx_pos = start_y, cursor_pos
        for i, line in enumerate(lines):
            if cx_pos <= len(line):
                cy = start_y + i
                break
            cx_pos -= len(line)
            # Account for the space eaten by wrapping
            if cx_pos > 0 and i + 1 < nlines:
                pass  # wrapped naturally
        try:
            stdscr.move(cy, min(x + cx_pos, x + w - 1))
        except curses.error:
            pass
        stdscr.refresh()

        ch = stdscr.getch()
        if ch == 27:
            curses.curs_set(0)
            return None
        elif ch in (10, curses.KEY_ENTER):
            curses.curs_set(0)
            return text
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            if cur > 0:
                text = text[:cur - 1] + text[cur:]
                cur -= 1
        elif ch == curses.KEY_LEFT:
            if cur > 0:
                cur -= 1
        elif ch == curses.KEY_RIGHT:
            if cur < len(text):
                cur += 1
        elif ch == curses.KEY_HOME:
            cur = 0
        elif ch == curses.KEY_END:
            cur = len(text)
        elif 32 <= ch < 127:
            text = text[:cur] + chr(ch) + text[cur:]
            cur += 1


# ── main menu ────────────────────────────────────────────────────────


def view_main(stdscr, state):
    mode = state["mode"]
    icon = STATUS_ICONS.get(state["status"], "")
    status = state["status"]
    if mode == "explore":
        items = [
            ("\uf051", "Next"), ("\uf048", "Prev"),
            ("\uf004", "Unlike" if status == "liked" else "Like"),
            ("\uf00d", "Undo dislike" if status == "disliked" else "Dislike"),
            ("\uf021", "Switch to liked mode"),
            ("\uf0c1", "Open source"), ("\uf013", "Settings"),
        ]
    else:
        items = [
            ("\uf051", "Next liked"), ("\uf048", "Prev"),
            ("\uf03e", "Browse liked"),
            ("\uf00d", "Undo dislike" if status == "disliked" else "Dislike"),
            ("\uf021", "Switch to explore mode"),
            ("\uf0c1", "Open source"), ("\uf013", "Settings"),
        ]
    info_lines = 3
    rows, cols = stdscr.getmaxyx()
    box_w = min(44, cols - 4)
    box_h = min(len(items) + info_lines + 4, rows - 2)
    bx, by = (cols - box_w) // 2, (rows - box_h) // 2
    selected = 0
    while True:
        stdscr.erase()
        draw_box(stdscr, by, bx, box_h, box_w, f"Wallpaper ({mode})")
        iy = by + 1
        fname = state["file"] or "none"
        if len(fname) > box_w - 6:
            fname = "..." + fname[-(box_w - 9):]
        draw_line(stdscr, iy, bx, box_w, f" {icon} {fname}",
                  curses.color_pair(C_ACCENT))
        draw_line(stdscr, iy + 1, bx, box_w,
                  f"   {state['topic']} \u2022 {state['source']}"
                  f"   \uf004 {state['liked']}  \uf128 {state['unrated']}",
                  curses.color_pair(C_DIM))
        draw_line(stdscr, iy + 2, bx, box_w, "", curses.color_pair(C_NORMAL))
        for i, (ic, label) in enumerate(items):
            y = iy + info_lines + i
            if y >= by + box_h - 3:
                break
            attr = (curses.color_pair(C_SELECTED) | curses.A_BOLD
                    if i == selected else curses.color_pair(C_NORMAL))
            draw_line(stdscr, y, bx, box_w, f" {ic}  {label}", attr)
        draw_sep(stdscr, by + box_h - 3, bx, box_w)
        draw_hints(stdscr, by + box_h - 2, bx, box_w,
                   [("\u23ce", "select"), ("?", "help"), ("esc", "quit")])
        stdscr.refresh()
        ch = stdscr.getch()
        if ch in (ord("q"), 27):
            return None
        elif ch == ord("?"):
            show_help(stdscr, [
                ("j / \u2193", "Move down"), ("k / \u2191", "Move up"),
                ("enter", "Run action"), ("esc / q", "Quit"),
            ])
        elif ch in (ord("j"), curses.KEY_DOWN):
            selected = min(selected + 1, len(items) - 1)
        elif ch in (ord("k"), curses.KEY_UP):
            selected = max(selected - 1, 0)
        elif ch in (10, curses.KEY_ENTER):
            return items[selected][1]


# ── browse liked ─────────────────────────────────────────────────────


def view_browse(stdscr):
    wallpapers = get_liked_wallpapers()
    if not wallpapers:
        return None
    rows, cols = stdscr.getmaxyx()
    box_w = min(56, cols - 4)
    visible = min(len(wallpapers), rows - 6)
    box_h = visible + 4
    bx, by = (cols - box_w) // 2, (rows - box_h) // 2
    selected = scroll = 0
    while True:
        stdscr.erase()
        draw_box(stdscr, by, bx, box_h, box_w, f"Liked ({len(wallpapers)})")
        for i in range(visible):
            idx = scroll + i
            if idx >= len(wallpapers):
                break
            wp = wallpapers[idx]
            fname, topic = wp["file"], wp["topic"]
            max_f = box_w - len(topic) - 8
            if len(fname) > max_f:
                fname = fname[:max(max_f - 3, 6)] + "..."
            text = f" {fname}"
            text += " " * max(box_w - 4 - len(text) - len(topic), 1) + topic
            attr = (curses.color_pair(C_SELECTED) | curses.A_BOLD
                    if idx == selected else curses.color_pair(C_NORMAL))
            draw_line(stdscr, by + 1 + i, bx, box_w, text, attr)
        draw_sep(stdscr, by + box_h - 3, bx, box_w)
        draw_hints(stdscr, by + box_h - 2, bx, box_w,
                   [("\u23ce", "set"), ("esc", "back")])
        stdscr.refresh()
        ch = stdscr.getch()
        if ch in (ord("q"), 27):
            return None
        elif ch in (ord("j"), curses.KEY_DOWN):
            if selected < len(wallpapers) - 1:
                selected += 1
                if selected >= scroll + visible:
                    scroll += 1
        elif ch in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
                if selected < scroll:
                    scroll -= 1
        elif ch in (10, curses.KEY_ENTER):
            return wallpapers[selected]["file"]


# ── settings view (config + rules + log) ─────────────────────────────

SETTINGS_SPEC = [
    ("MIN_WIDTH", "Min width (px)", "text"),
    ("REDDIT_MIN_SCORE", "Reddit min score", "text"),
    ("WALLHAVEN_MIN_FAVORITES", "WH min favorites", "text"),
    ("WALLHAVEN_EXCLUDE_TAGS", "WH exclude tags", "text"),
    ("LIKED_RESHOW_DAYS", "Liked reshow (days)", "text"),
    ("MAX_RETRIES", "Fetch retries", "text"),
    ("EXPLORE_HISTORY", "Explore undo depth", "text"),
    ("LIKED_HISTORY", "Liked undo depth", "text"),
    ("SOURCES", "Sources", "text"),
    ("SOURCE_ORDER", "Source order", "choice:ordered,random"),
    ("TRANSITION", "Transition", "transition"),
    ("RULE_TIMEOUT", "Rule timeout (s)", "text"),
    ("LOG_MAX_LINES", "Max log lines", "text"),
]
TRANSITIONS = [
    "none", "simple", "fade", "left", "right", "top", "bottom",
    "wipe", "wave", "grow", "center", "any", "outer", "random",
]


def parse_config():
    values = {}
    try:
        with open(CONFFILE) as f:
            for line in f:
                s = line.strip()
                if "=" in s and not s.startswith("#"):
                    key, _, val = s.partition("=")
                    val = val.strip()
                    if val.startswith('"'):
                        end = val.find('"', 1)
                        val = val[1:end] if end > 0 else val[1:]
                    elif val.startswith("'"):
                        end = val.find("'", 1)
                        val = val[1:end] if end > 0 else val[1:]
                    elif "#" in val:
                        val = val[:val.index("#")].strip()
                    values[key.strip()] = val
    except FileNotFoundError:
        pass
    return values


def save_setting(key, new_value):
    try:
        with open(CONFFILE) as f:
            lines = f.readlines()
        with open(CONFFILE, "w") as f:
            found = False
            for line in lines:
                s = line.strip()
                if s.startswith(f"{key}=") or s.startswith(f"{key} ="):
                    f.write(f'{key}="{new_value}"\n')
                    found = True
                else:
                    f.write(line)
            if not found:
                f.write(f'{key}="{new_value}"\n')
    except Exception:
        pass


def extract_transition_type(v):
    parts = v.split()
    for i, p in enumerate(parts):
        if p == "--transition-type" and i + 1 < len(parts):
            return parts[i + 1]
    return "simple"


# ── rules parser ─────────────────────────────────────────────────────


def parse_rules():
    """Parse rules.toml into list of {name, condition, topics}."""
    rules = []
    try:
        with open(RULESFILE) as f:
            content = f.read()
    except FileNotFoundError:
        return rules
    # Split by [section] headers
    sections = re.split(r'^\[([^\]]+)\]', content, flags=re.MULTILINE)
    # sections[0] is preamble (comments), then pairs of (name, body)
    for i in range(1, len(sections), 2):
        name = sections[i].strip()
        body = sections[i + 1] if i + 1 < len(sections) else ""
        cond = ""
        topics = []
        for line in body.splitlines():
            line = line.strip()
            if line.startswith("condition"):
                m = re.search(r'"(.+)"', line)
                if m:
                    cond = m.group(1)
            elif line.startswith("topics"):
                m = re.findall(r'"([^"]+)"', line)
                if m:
                    topics = m
        rules.append({"name": name, "condition": cond, "topics": topics})
    return rules


def save_rules(rules):
    """Write rules back to rules.toml with a header comment."""
    try:
        # Preserve original preamble (comments before first section)
        preamble = ""
        try:
            with open(RULESFILE) as f:
                for line in f:
                    if line.strip().startswith("[") and not line.strip().startswith("#"):
                        break
                    preamble += line
        except FileNotFoundError:
            pass
        with open(RULESFILE, "w") as f:
            f.write(preamble)
            for rule in rules:
                f.write(f"\n[{rule['name']}]\n")
                if rule["condition"]:
                    f.write(f'condition = "{rule["condition"]}"\n')
                if rule["topics"]:
                    quoted = ", ".join(f'"{t}"' for t in rule["topics"])
                    f.write(f"topics = [{quoted}]\n")
    except Exception:
        pass


# ── log viewer ───────────────────────────────────────────────────────


def view_log(stdscr):
    try:
        with open(LOGFILE) as f:
            lines = f.readlines()
    except FileNotFoundError:
        lines = ["(no log file)"]
    lines = [l.rstrip() for l in lines]
    rows, cols = stdscr.getmaxyx()
    box_w = min(70, cols - 2)
    visible = rows - 4
    box_h = visible + 3
    bx, by = (cols - box_w) // 2, (rows - box_h) // 2
    scroll = max(0, len(lines) - visible)  # start at bottom
    while True:
        stdscr.erase()
        draw_box(stdscr, by, bx, box_h, box_w,
                 f"Log ({len(lines)} lines)")
        for i in range(visible):
            idx = scroll + i
            if idx >= len(lines):
                break
            text = " " + lines[idx][:box_w - 4]
            draw_line(stdscr, by + 1 + i, bx, box_w, text,
                      curses.color_pair(C_DIM))
        draw_sep(stdscr, by + box_h - 2, bx, box_w)
        draw_hints(stdscr, by + box_h - 1, bx, box_w,
                   [("j/k", "scroll"), ("G", "end"), ("g", "top"),
                    ("esc", "back")])
        stdscr.refresh()
        ch = stdscr.getch()
        if ch in (ord("q"), 27):
            return
        elif ch in (ord("j"), curses.KEY_DOWN):
            if scroll < len(lines) - visible:
                scroll += 1
        elif ch in (ord("k"), curses.KEY_UP):
            if scroll > 0:
                scroll -= 1
        elif ch == ord("G"):
            scroll = max(0, len(lines) - visible)
        elif ch == ord("g"):
            scroll = 0


# ── settings hub (tabs: config / rules / log) ───────────────────────


def view_settings(stdscr):
    """Settings hub with tab switching."""
    tabs = ["\uf013 Config", "\uf044 Rules", "\uf15c Log"]
    tab = 0
    while True:
        if tab == 0:
            result = _tab_config(stdscr, tabs, tab)
        elif tab == 1:
            result = _tab_rules(stdscr, tabs, tab)
        else:
            result = _tab_log(stdscr, tabs, tab)
        if result is None:
            return
        elif isinstance(result, int):
            tab = result


def _draw_tabs(stdscr, by, bx, box_w, tabs, active):
    """Draw tab bar inside the box."""
    cx = bx + 2
    for i, label in enumerate(tabs):
        attr = (curses.color_pair(C_HEADER) | curses.A_BOLD
                if i == active else curses.color_pair(C_DIM))
        try:
            stdscr.addstr(by, cx, label, attr)
            if i < len(tabs) - 1:
                stdscr.addstr("  \u2502  ", curses.color_pair(C_DIM))
                cx += len(label) + 5
            else:
                cx += len(label)
        except curses.error:
            pass


def _tab_config(stdscr, tabs, active_tab):
    values = parse_config()
    rows, cols = stdscr.getmaxyx()
    box_w = min(52, cols - 2)
    n = len(SETTINGS_SPEC)
    visible = min(n, rows - 7)
    box_h = visible + 5  # tabs + items + sep + hints
    bx, by = (cols - box_w) // 2, (rows - box_h) // 2
    selected = scroll = 0
    label_w = max(len(s[1]) for s in SETTINGS_SPEC) + 2
    while True:
        stdscr.erase()
        draw_box(stdscr, by, bx, box_h, box_w, "Settings")
        _draw_tabs(stdscr, by + 1, bx, box_w, tabs, active_tab)
        draw_sep(stdscr, by + 2, bx, box_w)
        for i in range(visible):
            idx = scroll + i
            if idx >= n:
                break
            key, name, stype = SETTINGS_SPEC[idx]
            raw = values.get(key, "")
            display = extract_transition_type(raw) if stype == "transition" else raw
            val_w = box_w - label_w - 5
            if len(display) > val_w:
                display = display[:val_w - 1] + "\u2026"
            is_sel = idx == selected
            attr = (curses.color_pair(C_SELECTED) | curses.A_BOLD
                    if is_sel else curses.color_pair(C_NORMAL))
            val_attr = (curses.color_pair(C_SELECTED) | curses.A_BOLD
                        if is_sel else curses.color_pair(C_ACCENT))
            text = f" {name.ljust(label_w)}"
            try:
                stdscr.addstr(by + 3 + i, bx + 1, text[:box_w - 2], attr)
                stdscr.addstr(display, val_attr)
                rem = box_w - 2 - len(text) - len(display)
                if rem > 0:
                    stdscr.addstr(" " * rem, attr)
            except curses.error:
                pass
        draw_sep(stdscr, by + box_h - 2, bx, box_w)
        draw_hints(stdscr, by + box_h - 1, bx, box_w,
                   [("\u23ce", "edit"), ("H/L", "tabs"),
                    ("?", "help"), ("esc", "back")])
        stdscr.refresh()
        ch = stdscr.getch()
        if ch in (27,):
            return None
        elif ch in (9, ord("L")):  # Tab / L
            return (active_tab + 1) % len(tabs)
        elif ch in (curses.KEY_BTAB, ord("H")):  # Shift+Tab / H
            return (active_tab - 1) % len(tabs)
        elif ch == ord("?"):
            show_help(stdscr, [
                ("j / \u2193", "Move down"), ("k / \u2191", "Move up"),
                ("enter", "Edit value (text) / cycle (choice)"),
                ("H / L / tab", "Switch tab"), ("esc", "Back to menu"),
            ])
        elif ch in (ord("j"), curses.KEY_DOWN):
            if selected < n - 1:
                selected += 1
                if selected >= scroll + visible:
                    scroll += 1
        elif ch in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
                if selected < scroll:
                    scroll -= 1
        elif ch in (10, curses.KEY_ENTER):
            key, name, stype = SETTINGS_SPEC[selected]
            raw = values.get(key, "")
            if stype.startswith("choice:"):
                choices = stype.split(":", 1)[1].split(",")
                ci = choices.index(raw) if raw in choices else 0
                nv = choices[(ci + 1) % len(choices)]
                save_setting(key, nv)
                values[key] = nv
            elif stype == "transition":
                ct = extract_transition_type(raw)
                ci = TRANSITIONS.index(ct) if ct in TRANSITIONS else 0
                nt = TRANSITIONS[(ci + 1) % len(TRANSITIONS)]
                nv = f"--transition-type {nt}"
                save_setting(key, nv)
                values[key] = nv
            else:
                nv = text_input(stdscr, by + box_h - 1, bx + 1,
                                box_w - 2, f"{name}: ", raw)
                if nv is not None:
                    save_setting(key, nv)
                    values[key] = nv


def _wrap(text, width):
    if not text or width <= 0:
        return [text or ""]
    lines = []
    while len(text) > width:
        brk = text.rfind(" ", 0, width)
        if brk <= 0:
            brk = width
        lines.append(text[:brk])
        text = text[brk:].lstrip()
    if text:
        lines.append(text)
    return lines or [""]


def _build_rule_rows(rules):
    """Flatten rules into navigable rows: (type, rule_idx, topic_idx)."""
    items = []
    for ri, rule in enumerate(rules):
        items.append(("rule", ri, None))
        items.append(("cond", ri, None))
        for ti in range(len(rule["topics"])):
            items.append(("topic", ri, ti))
    return items


def _tab_rules(stdscr, tabs, active_tab):
    rules = parse_rules()
    rows, cols = stdscr.getmaxyx()
    box_w = min(52, cols - 2)
    inner = box_w - 4
    visible = rows - 7
    box_h = visible + 5
    bx, by = (cols - box_w) // 2, (rows - box_h) // 2
    selected = scroll = 0

    while True:
        items = _build_rule_rows(rules)
        n = len(items)
        if selected >= n:
            selected = max(0, n - 1)

        stdscr.erase()
        draw_box(stdscr, by, bx, box_h, box_w, "Settings")
        _draw_tabs(stdscr, by + 1, bx, box_w, tabs, active_tab)
        draw_sep(stdscr, by + 2, bx, box_w)

        if not items:
            draw_line(stdscr, by + 3, bx, box_w, " (no rules \u2014 press a to add)",
                      curses.color_pair(C_DIM))

        for i in range(visible):
            idx = scroll + i
            if idx >= n:
                break
            itype, ri, ti = items[idx]
            rule = rules[ri]
            is_sel = idx == selected
            y = by + 3 + i

            if itype == "rule":
                text = f" [{rule['name']}]"
                attr = (curses.color_pair(C_SELECTED) | curses.A_BOLD
                        if is_sel
                        else curses.color_pair(C_HEADER) | curses.A_BOLD)
                draw_line(stdscr, y, bx, box_w, text, attr)

            elif itype == "cond":
                cond = rule["condition"] or "(no condition)"
                text = f"   \uf0e7 {cond}"
                if len(text) > inner:
                    text = text[:inner - 1] + "\u2026"
                attr = (curses.color_pair(C_SELECTED) | curses.A_BOLD
                        if is_sel else curses.color_pair(C_DIM))
                draw_line(stdscr, y, bx, box_w, text, attr)

            elif itype == "topic":
                is_last = ti == len(rule["topics"]) - 1
                branch = "\u2514" if is_last else "\u251c"
                text = f"   {branch} {rule['topics'][ti]}"
                attr = (curses.color_pair(C_SELECTED) | curses.A_BOLD
                        if is_sel else curses.color_pair(C_NORMAL))
                draw_line(stdscr, y, bx, box_w, text, attr)

        draw_sep(stdscr, by + box_h - 2, bx, box_w)
        draw_hints(stdscr, by + box_h - 1, bx, box_w,
                   [("\u23ce", "edit"), ("a", "add"), ("d", "del"),
                    ("H/L", "tabs"), ("?", "help")])
        stdscr.refresh()

        ch = stdscr.getch()
        if ch == 27:
            return None
        elif ch in (9, ord("L")):
            return (active_tab + 1) % len(tabs)
        elif ch in (curses.KEY_BTAB, ord("H")):
            return (active_tab - 1) % len(tabs)
        elif ch == ord("?"):
            show_help(stdscr, [
                ("j / \u2193", "Move down"), ("k / \u2191", "Move up"),
                ("enter", "Edit selected item"),
                ("a", "Add (rule on header, topic otherwise)"),
                ("d", "Delete selected item"),
                ("H / L / tab", "Switch tab"), ("esc", "Back"),
            ])
        elif ch in (ord("j"), curses.KEY_DOWN):
            if selected < n - 1:
                selected += 1
                if selected >= scroll + visible:
                    scroll += 1
        elif ch in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
                if selected < scroll:
                    scroll -= 1
        elif ch == ord("a"):
            if not items:
                name = text_input(stdscr, by + box_h - 1, bx + 1,
                                  box_w - 2, "New rule name: ")
                if name:
                    rules.append({"name": name, "condition": "", "topics": []})
                    save_rules(rules)
            else:
                itype, ri, ti = items[selected]
                if itype == "rule":
                    name = text_input(stdscr, by + box_h - 1, bx + 1,
                                      box_w - 2, "New rule name: ")
                    if name:
                        rules.insert(ri + 1, {"name": name, "condition": "", "topics": []})
                        save_rules(rules)
                else:
                    topic = text_input(stdscr, by + box_h - 1, bx + 1,
                                       box_w - 2, "New topic: ")
                    if topic:
                        rules[ri]["topics"].append(topic)
                        save_rules(rules)
        elif ch == ord("d"):
            if not items:
                continue
            itype, ri, ti = items[selected]
            if itype == "rule":
                rules.pop(ri)
                save_rules(rules)
            elif itype == "topic":
                rules[ri]["topics"].pop(ti)
                save_rules(rules)
        elif ch in (10, curses.KEY_ENTER):
            if not items:
                continue
            itype, ri, ti = items[selected]
            if itype == "rule":
                name = text_input(stdscr, by + box_h - 1, bx + 1,
                                  box_w - 2, "Name: ", rules[ri]["name"])
                if name:
                    rules[ri]["name"] = name
                    save_rules(rules)
            elif itype == "cond":
                val = text_input(stdscr, by + box_h - 1, bx + 1,
                                 box_w - 2, "Condition: ",
                                 rules[ri]["condition"])
                if val is not None:
                    rules[ri]["condition"] = val
                    save_rules(rules)
            elif itype == "topic":
                val = text_input(stdscr, by + box_h - 1, bx + 1,
                                 box_w - 2, "Topic: ",
                                 rules[ri]["topics"][ti])
                if val is not None:
                    if val.strip():
                        rules[ri]["topics"][ti] = val.strip()
                    else:
                        rules[ri]["topics"].pop(ti)
                    save_rules(rules)


def _tab_log(stdscr, tabs, active_tab):
    try:
        with open(LOGFILE) as f:
            lines = [l.rstrip() for l in f.readlines()]
    except FileNotFoundError:
        lines = ["(no log file)"]
    rows, cols = stdscr.getmaxyx()
    box_w = min(70, cols - 2)
    visible = rows - 7
    box_h = visible + 5
    bx, by = (cols - box_w) // 2, (rows - box_h) // 2
    scroll = max(0, len(lines) - visible)
    while True:
        stdscr.erase()
        draw_box(stdscr, by, bx, box_h, box_w, "Settings")
        _draw_tabs(stdscr, by + 1, bx, box_w, tabs, active_tab)
        draw_sep(stdscr, by + 2, bx, box_w)
        for i in range(visible):
            idx = scroll + i
            if idx >= len(lines):
                break
            draw_line(stdscr, by + 3 + i, bx, box_w,
                      " " + lines[idx][:box_w - 4],
                      curses.color_pair(C_DIM))
        draw_sep(stdscr, by + box_h - 2, bx, box_w)
        draw_hints(stdscr, by + box_h - 1, bx, box_w,
                   [("j/k", "scroll"), ("G", "end"), ("g", "top"),
                    ("H/L", "tabs"), ("esc", "back")])
        stdscr.refresh()
        ch = stdscr.getch()
        if ch == 27:
            return None
        elif ch in (9, ord("L")):  # Tab / L
            return (active_tab + 1) % len(tabs)
        elif ch in (curses.KEY_BTAB, ord("H")):  # Shift+Tab / H
            return (active_tab - 1) % len(tabs)
        elif ch in (ord("j"), curses.KEY_DOWN):
            if scroll < len(lines) - visible:
                scroll += 1
        elif ch in (ord("k"), curses.KEY_UP):
            if scroll > 0:
                scroll -= 1
        elif ch == ord("G"):
            scroll = max(0, len(lines) - visible)
        elif ch == ord("g"):
            scroll = 0


# ── main ─────────────────────────────────────────────────────────────


def main(stdscr):
    init_colors(accent_fg=curses.COLOR_GREEN, bright_fg=curses.COLOR_MAGENTA)
    while True:
        state = get_state()
        action = view_main(stdscr, state)
        if action is None:
            break
        elif action in ("Next", "Next liked"):
            wp_cmd_bg("next")
        elif action == "Prev":
            wp_cmd_bg("prev")
        elif action == "Like":
            wp_cmd("like")
        elif action in ("Unlike", "Undo dislike"):
            wp_cmd("unrate")
        elif action == "Dislike":
            wp_cmd("dislike")
        elif action.startswith("Switch to"):
            wp_cmd("mode")
        elif action == "Open source":
            wp_cmd("source")
            break
        elif action == "Settings":
            view_settings(stdscr)
        elif action == "Browse liked":
            pick = view_browse(stdscr)
            if pick:
                wp_cmd("set", os.path.join(WALLDIR, pick))


if __name__ == "__main__":
    os.environ.setdefault("ESCDELAY", "25")
    curses.wrapper(main)
